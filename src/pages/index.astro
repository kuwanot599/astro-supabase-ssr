---
import { createClient } from '@supabase/supabase-js'

// SSRモードなので、アクセスされるたびにこのコードが実行されます
const supabase = createClient(
  import.meta.env.SUPABASE_URL,
  import.meta.env.SUPABASE_ANON_KEY
)

// Supabaseからリアルタイムにデータを取得
const { data: posts, error } = await supabase.from('posts').select('*')

// SSRが動作しているか確認するための現在時刻
const requestTime = new Date().toLocaleTimeString('ja-JP');
---

<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<title>Astro SSR + Supabase</title>
	</head>
	<body>
		<h1>Astro SSR 動作確認</h1>
		<p>ページ生成時刻（リロードで更新されます）: <strong>{requestTime}</strong></p>

		<h2>Supabaseからのデータ</h2>
		{error && <p style="color: red;">エラー: {error.message}</p>}
		<ul>
			{posts?.map((post) => (
				<li>{post.title} (ID: {post.id})</li>
			))}
		</ul>
	</body>
</html>